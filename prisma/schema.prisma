// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id                           String    @id
    email                        String    @unique
    emailVerified                Boolean   @default(false)
    name                         String?
    password                     String?
    verificationCode             String? // Temporary OTP code for email verification
    verificationCodeExpiresAt    DateTime? // OTP expiration time
    onboarded                    Boolean   @default(false)
    aiNoteGenerationCount        Int       @default(0) // AI note generation usage (0-3 per 24h)
    aiNoteGenerationCountResetAt DateTime? // Timestamp when 24h reset should occur
    badges                       String[]  @default([])
    encryptedPin                 String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    onboarding      Onboarding?
    plan            Plan?
    journalEntries  JournalEntry[]
    insights        Insight[]
    monthlyInsights MonthlyInsight[]
    accounts        Account[]
    sessions        Session[]

    image    String?
    holidays Holiday[]

    @@index([emailVerified])
    @@map("user")
}

model Account {
    id                    String    @id @default(cuid())
    userId                String
    accountId             String
    providerId            String
    accessToken           String?
    refreshToken          String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    idToken               String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, accountId])
    @@index([userId])
    @@map("account")
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("session")
}

model Onboarding {
    id               Int       @id @default(autoincrement())
    user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId           String    @unique
    age              Int
    goals            String
    goalSpecificInfo Json
    timeAvailability Int
    activities       String
    energeticTime    String
    daysOff          String[]  @default([])
    additionalNotes  String?
    termsAccepted    Boolean   @default(false)
    completedAt      DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    @@index([userId])
}

model Plan {
    id           Int      @id @default(autoincrement())
    userId       String
    daysOff      String[] @default([])
    hoursSummary Json? // { "Monday": 8, "Tuesday": 7, ..., "weekTotal": 40 }
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    tasks Task[]

    @@unique([userId]) // One plan per user
    @@index([userId])
    @@map("plan")
}

model Task {
    id            Int        @id @default(autoincrement())
    planId        Int
    day           String // "Monday", etc.
    timeRange     String // "10:00-11:00"
    activity      String // Description of the activity
    status        TaskStatus @default(pending) // Enum
    notes         String?
    createdAt     DateTime   @default(now())
    updatedAt     DateTime   @updatedAt
    personalNotes String     @default("")
    // Relations
    plan          Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)

    @@index([planId, status]) // For quick status filters
    @@map("task")
}

enum TaskStatus {
    pending
    done
    partial
}

enum Mood {
    HAPPY
    SAD
    ANGRY
    CALM
    EXCITED
    ANXIOUS
    NEUTRAL
    // Add more as needed
}

model JournalEntry {
    id           Int      @id @default(autoincrement())
    userId       String
    date         DateTime @db.Date // One entry per day
    title        String // Title of the journal entry
    finalContent String // User-edited final version
    mood         Mood?
    pinned       Boolean  @default(false)
    isPrivate    Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, date])
    @@index([userId])
    @@index([userId, pinned]) // Fast pinned queries
    @@index([userId, mood])
    @@index([userId, title]) // Fast title search queries
}

model Insight {
    id                 Int      @id @default(autoincrement())
    userId             String
    weekStartDate      DateTime
    weekEndDate        DateTime
    totalTasks         Int?
    completedTasks     Int?
    partialTasks       String[] @default([])
    averageTimeSpent   Float?
    consistencyScore   Float?
    trendingCompletion Float?
    topPerformingDay   String?
    suggestions        String?
    planSuggestions    String?  @db.Text
    createdAt          DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, weekStartDate])
    @@index([userId])
}

model MonthlyInsight {
    id               Int      @id @default(autoincrement())
    userId           String
    year             Int
    month            Int // 1-12
    totalTasks       Int      @default(0)
    completedTasks   Int      @default(0)
    partialTasks     Int      @default(0)
    averageTimeSpent Float    @default(0)
    completionRate   Float    @default(0)
    holidaysTaken    Int      @default(0)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints: One record per user per month per year
    @@unique([userId, year, month])
    @@index([userId, year])
    @@map("monthly_insight")
}

model Verification {
    id         String   @id
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([identifier])
    @@map("verification")
}

// LangGraph Checkpoint Tables (managed by postgresSaver)
model CheckpointMigration {
    v Int @id @map("v")

    @@map("checkpoint_migrations")
}

model Checkpoint {
    threadId           String  @map("thread_id")
    checkpointNs       String  @default("") @map("checkpoint_ns")
    checkpointId       String  @map("checkpoint_id")
    parentCheckpointId String? @map("parent_checkpoint_id")
    type               String? @map("type")
    checkpoint         Json    @map("checkpoint")
    metadata           Json    @default("{}") @map("metadata")

    @@id([threadId, checkpointNs, checkpointId])
    @@map("checkpoints")
}

model CheckpointBlob {
    threadId     String @map("thread_id")
    checkpointNs String @default("") @map("checkpoint_ns")
    channel      String @map("channel")
    version      String @map("version")
    type         String @map("type")
    blob         Bytes? @map("blob")

    @@id([threadId, checkpointNs, channel, version])
    @@map("checkpoint_blobs")
}

model CheckpointWrite {
    threadId     String  @map("thread_id")
    checkpointNs String  @default("") @map("checkpoint_ns")
    checkpointId String  @map("checkpoint_id")
    taskId       String  @map("task_id")
    idx          Int     @map("idx")
    channel      String  @map("channel")
    type         String? @map("type")
    blob         Bytes   @map("blob")

    @@id([threadId, checkpointNs, checkpointId, taskId, idx])
    @@map("checkpoint_writes")
}

model Holiday {
    id        Int      @id @default(autoincrement())
    userId    String
    date      DateTime @db.Date // Specific date (e.g., 2025-01-15)
    reason    String? // Optional: e.g., "Meeting", "Sick leave"
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints: One holiday per user per date
    @@unique([userId, date])
    @@index([userId])
    @@map("holiday")
}
