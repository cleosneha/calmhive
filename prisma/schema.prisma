// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                           String    @id
    email                        String    @unique
    emailVerified                Boolean   @default(false)
    name                         String?
    password                     String?
    verificationCode             String? // Temporary OTP code for email verification
    verificationCodeExpiresAt    DateTime? // OTP expiration time
    onboarded                    Boolean   @default(false)
    currentPlan                  Json? // Generated weekly plan (only after T&C)
    aiNoteGenerationCount        Int       @default(0) // AI note generation usage (0-3 per 24h)
    aiNoteGenerationCountResetAt DateTime? // Timestamp when 24h reset should occur
    createdAt                    DateTime  @default(now())
    updatedAt                    DateTime  @updatedAt

    onboarding     Onboarding?
    plan           Plan[]
    journalEntries JournalEntry[]
    insights       Insight[]
    accounts       Account[]
    sessions       Session[]

    image String?

    @@index([emailVerified])
    @@map("user")
}

model Account {
    id                    String    @id @default(cuid())
    userId                String
    accountId             String
    providerId            String
    accessToken           String?
    refreshToken          String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    idToken               String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, accountId])
    @@index([userId])
    @@map("account")
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("session")
}

model Onboarding {
    id               Int       @id @default(autoincrement())
    user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId           String    @unique
    age              Int
    goals            String
    goalSpecificInfo Json
    timeAvailability Int
    activities       String
    energeticTime    String
    daysOff          String[]  @default([])
    additionalNotes  String?
    termsAccepted    Boolean   @default(false)
    completedAt      DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    @@index([userId])
}

model Plan {
    id           Int      @id @default(autoincrement())
    userId       String
    daysOff      String[] @default([])
    hoursSummary Json? // { "Monday": 8, "Tuesday": 7, ..., "weekTotal": 40 }
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    tasks Task[]

    @@unique([userId]) // One plan per user
    @@index([userId])
    @@map("plan")
}

model Task {
    id            Int        @id @default(autoincrement())
    planId        Int
    day           String // "Monday", etc.
    timeRange     String // "10:00-11:00"
    activity      String // Description of the activity
    status        TaskStatus @default(pending) // Enum
    notes         String?
    createdAt     DateTime   @default(now())
    updatedAt     DateTime   @updatedAt
    personalNotes String     @default("")
    // Relations
    plan          Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)

    @@index([planId, status]) // For quick status filters
    @@map("task")
}

// Enums for type safety & performance
enum PlanStatus {
    active
    completed
}

enum TaskStatus {
    pending
    done
    skipped
    partial
}

model JournalEntry {
    id           Int      @id @default(autoincrement())
    userId       String
    date         DateTime @db.Date // One entry per day
    finalContent String // User-edited final version
    moodScore    Decimal? @db.Decimal(3, 1) // 0.0 - 10.0
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, date])
    @@index([userId])
}

model Insight {
    id                 Int      @id @default(autoincrement())
    userId             String
    weekStartDate      DateTime
    weekEndDate        DateTime
    title              String
    narrativeSummary   String
    keyPatterns        Json // Gentle observations
    suggestions        Json // Optional AI suggestions
    taskCompletionRate Decimal  @db.Decimal(5, 2) // 0.00 - 100.00
    journalFrequency   Int // Journals written this week
    generatedAt        DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, weekStartDate])
    @@index([userId])
}

model Verification {
    id         String   @id
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([identifier])
    @@map("verification")
}

// LangGraph Checkpoint Tables (managed by postgresSaver)
model CheckpointMigration {
    v Int @id @map("v")

    @@map("checkpoint_migrations")
}

model Checkpoint {
    threadId           String  @map("thread_id")
    checkpointNs       String  @default("") @map("checkpoint_ns")
    checkpointId       String  @map("checkpoint_id")
    parentCheckpointId String? @map("parent_checkpoint_id")
    type               String? @map("type")
    checkpoint         Json    @map("checkpoint")
    metadata           Json    @default("{}") @map("metadata")

    @@id([threadId, checkpointNs, checkpointId])
    @@map("checkpoints")
}

model CheckpointBlob {
    threadId     String @map("thread_id")
    checkpointNs String @default("") @map("checkpoint_ns")
    channel      String @map("channel")
    version      String @map("version")
    type         String @map("type")
    blob         Bytes? @map("blob")

    @@id([threadId, checkpointNs, channel, version])
    @@map("checkpoint_blobs")
}

model CheckpointWrite {
    threadId     String  @map("thread_id")
    checkpointNs String  @default("") @map("checkpoint_ns")
    checkpointId String  @map("checkpoint_id")
    taskId       String  @map("task_id")
    idx          Int     @map("idx")
    channel      String  @map("channel")
    type         String? @map("type")
    blob         Bytes   @map("blob")

    @@id([threadId, checkpointNs, checkpointId, taskId, idx])
    @@map("checkpoint_writes")
}
