// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    name      String?
    onboarded Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    onboarding     Onboarding?
    plan           Plan[]
    journalEntries JournalEntry[]
    insights       Insight[]
    isVerified     Boolean        @default(false)
}

model Onboarding {
    id        Int      @id @default(autoincrement())
    user      User     @relation(fields: [userId], references: [id])
    userId    Int      @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    responses Json
}

model Plan {
    id                 Int        @id @default(autoincrement())
    userId             Int        @unique // One active plan per user
    title              String
    description        String?
    tasks              Json // Array of task objects with status/notes
    aiGeneratedContent Json? // Raw AI output for debugging
    generatedAt        DateTime   @default(now())
    status             PlanStatus @default(ACTIVE)
    createdAt          DateTime   @default(now())
    updatedAt          DateTime   @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PlanStatus {
    ACTIVE
    COMPLETED
    ARCHIVED
}

model JournalEntry {
    id               Int      @id @default(autoincrement())
    userId           Int
    date             DateTime @db.Date // One entry per day
    rawResponses     Json // Original user answers
    aiGeneratedDraft String? // AI-created content
    finalContent     String // User-edited final version
    moodScore        Decimal? @db.Decimal(3, 1) // 0.0 - 10.0
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, date])
}

model Insight {
    id                 Int      @id @default(autoincrement())
    userId             Int
    weekStartDate      DateTime
    weekEndDate        DateTime
    title              String
    narrativeSummary   String
    keyPatterns        Json // Gentle observations
    suggestions        Json // Optional AI suggestions
    taskCompletionRate Decimal  @db.Decimal(5, 2) // 0.00 - 100.00
    journalFrequency   Int // Journals written this week
    generatedAt        DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, weekStartDate])
}
