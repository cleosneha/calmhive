// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                        String    @id
    email                     String    @unique
    emailVerified             Boolean   @default(false)
    name                      String?
    password                  String?
    verificationCode          String? // Temporary OTP code for email verification
    verificationCodeExpiresAt DateTime? // OTP expiration time
    onboarded                 Boolean   @default(false)
    createdAt                 DateTime  @default(now())
    updatedAt                 DateTime  @updatedAt

    onboarding     Onboarding?
    plan           Plan[]
    journalEntries JournalEntry[]
    insights       Insight[]
    accounts       Account[]
    sessions       Session[]

    image String?

    @@index([emailVerified])
    @@map("user")
}

model Account {
    id                    String    @id @default(cuid())
    userId                String
    accountId             String
    providerId            String
    accessToken           String?
    refreshToken          String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    idToken               String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, accountId])
    @@index([userId])
    @@map("account")
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("session")
}

model Onboarding {
    id        Int      @id @default(autoincrement())
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    responses Json
}

model Plan {
    id          Int      @id @default(autoincrement())
    userId      String
    title       String
    description String?
    tasks       Json
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model JournalEntry {
    id           Int      @id @default(autoincrement())
    userId       String
    date         DateTime @db.Date // One entry per day
    finalContent String // User-edited final version
    moodScore    Decimal? @db.Decimal(3, 1) // 0.0 - 10.0
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, date])
    @@index([userId])
}

model Insight {
    id                 Int      @id @default(autoincrement())
    userId             String
    weekStartDate      DateTime
    weekEndDate        DateTime
    title              String
    narrativeSummary   String
    keyPatterns        Json // Gentle observations
    suggestions        Json // Optional AI suggestions
    taskCompletionRate Decimal  @db.Decimal(5, 2) // 0.00 - 100.00
    journalFrequency   Int // Journals written this week
    generatedAt        DateTime @default(now())

    // Relations
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Constraints
    @@unique([userId, weekStartDate])
    @@index([userId])
}

model Verification {
    id         String   @id
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([identifier])
    @@map("verification")
}
